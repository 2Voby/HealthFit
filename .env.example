# Compose ports
API_EXTERNAL_PORT=18247
ADMIN_FRONT_EXTERNAL_PORT=3000
CLIENT_FRONT_EXTERNAL_PORT=3001
POSTGRES_EXTERNAL_PORT=15429
REDIS_EXTERNAL_PORT=16371
POSTGRES_TEST_EXTERNAL_PORT=15439
REDIS_TEST_EXTERNAL_PORT=16381

# Frontend build and dev env
VITE_API_URL=http://localhost:18247
VITE_WS_URL=ws://localhost:18247

# Backend app
APP_NAME=Users Service
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true

# Postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=app

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Sessions
SESSION_COOKIE_NAME=session_id
SESSION_TTL_SECONDS=604800
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax

# Bootstrap and schema setup
DB_GENERATE_SCHEMAS=true
BOOTSTRAP_MOCK_DATA=true
BOOTSTRAP_AUTHORITIES_CSV=read_users,edit_users,edit_elements
BOOTSTRAP_ADMIN_LOGIN=admin
BOOTSTRAP_ADMIN_PASSWORD=admin12345
BOOTSTRAP_ADMIN_AUTHORITIES_CSV=read_users,edit_users,edit_elements
