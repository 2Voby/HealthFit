APP_NAME=Users Service
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=app

REDIS_HOST=redis
REDIS_PORT=6379
