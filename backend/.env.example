SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax

DB_GENERATE_SCHEMAS=true
BOOTSTRAP_MOCK_DATA=true

BOOTSTRAP_AUTHORITIES_CSV=read_users,edit_users,edit_elements
BOOTSTRAP_ADMIN_LOGIN=admin
BOOTSTRAP_ADMIN_PASSWORD=admin12345
BOOTSTRAP_ADMIN_AUTHORITIES_CSV=read_users,edit_users,edit_elements
